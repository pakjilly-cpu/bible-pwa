{
  "buildCommand": "",
  "outputDirectory": "public",
  "framework": null,
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!data|icon|manifest|sw).*)", "destination": "/index.html" }
  ]
}
